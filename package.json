{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:phpunit": "php vendor/bin/phpunit",
        "test:phpstan": "php vendor/bin/phpstan analyse app --memory-limit=256M",
        "test:all": "npm run test && npm run test:phpunit && npm run test:phpstan"
    },
    "devDependencies": {
        "@databases/pg-test": "^3.1.2",
        "axios": "^1.15.0",
        "concurrently": "^9.2.1",
        "laravel-vite-plugin": "^3.0.1",
        "pg": "^8.20.0",
        "sass": "^1.99.0",
        "vite": "^8.0.8",
        "vitest": "^4.1.4"
    }
}
