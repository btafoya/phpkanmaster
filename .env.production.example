# phpKanMaster — Production Environment Template
# Copy this to .env on your production server
#
# REQUIRED: Fill in all values below
# Generated passwords should be strong random strings (32+ chars)

APP_NAME=phpKanMaster
APP_ENV=production
APP_KEY=  # Run: docker compose exec app php artisan key:generate
APP_DEBUG=false
APP_URL=https://your-domain.com

# Generate a strong bcrypt hash for your password:
#   docker compose exec app php -r "echo password_hash('your_password', PASSWORD_BCRYPT);"
APP_USER=admin
APP_PASSWORD_HASH=  # Required — bcrypt hash from above

# Database
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=kanban
DB_USERNAME=kanban
DB_PASSWORD=  # Strong random password — set in docker-compose.yml POSTGRES_PASSWORD

# PostgREST (browser API)
PGRST_BASE_URL=/api

# PostgREST database password (set this in docker-compose.yml or .env)
# POSTGREST_PASSWORD=  # Must match what's in docker-compose.yml

# Logging — use daily for production (rotated log files)
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Session
SESSION_DRIVER=database
SESSION_TABLE=sessions
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

# Notification channels (enable/disable only when you configure the tokens below)
NOTIFY_PUSHOVER=false
NOTIFY_TWILIO=false
NOTIFY_ROCKETCHAT=false

# Pushover (if enabled — also set NOTIFY_PUSHOVER=true)
PUSHOVER_TOKEN=
PUSHOVER_USER_KEY=

# Twilio (if enabled — also set NOTIFY_TWILIO=true)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+15550000000

# RocketChat (if enabled — also set NOTIFY_ROCKETCHAT=true)
ROCKETCHAT_URL=
ROCKETCHAT_TOKEN=
ROCKETCHAT_CHANNEL=#general

# Cache and queues
CACHE_STORE=database
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log

# Optional: Email (only needed if sending email)
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_FROM_ADDRESS="phpkanmaster@example.com"
# MAIL_FROM_NAME="${APP_NAME}"